---
import Vue from './icons/Vue.astro'
import Typescript from './icons/Typescript.astro'
import JavaScript from './icons/JavaScript.astro'
import Laravel from './icons/Laravel.astro'
import Tailwind from './icons/Tailwind.astro'
import Firebase from './icons/Firebase.astro'
import Figma from './icons/Figma.astro'

const skills = [
  { name: 'Vue.js', icon: Vue },
  { name: 'TypeScript', icon: Typescript },
  { name: 'JavaScript', icon: JavaScript },
  { name: 'Laravel', icon: Laravel },
  { name: 'Tailwind CSS', icon: Tailwind },
  { name: 'Firebase', icon: Firebase },
  { name: 'Figma', icon: Figma },
]
---

<div class="flex flex-wrap gap-3">
  {skills.map(({ name, icon: Icon }) => (
    <span class="flex items-center gap-2 bg-blue-300/30 dark:bg-blue-400/30 text-gray-800 dark:text-white rounded-full py-2 px-4 text-sm font-medium">
      <Icon class="size-5" />
      {name}
    </span>
  ))}
</div>
