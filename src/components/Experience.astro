---
import ExperienceItems from "./ExperienceItems.astro"

const experience = [
    {
        title: 'Freelance Web Developer · Mancruz',
        date: 'February 2024 – April 2024',
        description: 'Designed and developed a full website for a Dogo Argentino breeder — breed information, photo gallery, and contact form via PHP. Defined requirements directly with the client, delivered in 2 weeks. The site is live and actively used today.',
        link: 'https://mancruz.vercel.app/',
        badge: 'Freelance'
    }
]
---


<ol class="relative border-s border-blue-400 dark:border-gray-700 ml-3">     
    
    {
        experience.map((experience) => (
             <li class="mb-10 ms-6">            
                <ExperienceItems {...experience} />
            </li>
        ))
    }
</ol>
