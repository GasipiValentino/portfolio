---
import Layout from '../../layouts/Layout.astro';
import Label from '../../components/Label.astro';
import IntroSocial from '../../components/IntroSocial.astro';
import Linkedin from '../../components/icons/Linkedin.astro';
import Github from '../../components/icons/Github.astro';
import Bento from '../../components/icons/Bento.astro';
import Mail from '../../components/icons/Mail.astro';
import Suitcase from '../../components/icons/Suitcase.astro';
import Experience from '../../components/Experience.astro';
import SectionContainer from '../../components/SectionContainer.astro';
import Projects from '../../components/Projects.astro';
import  Code  from '../../components/icons/Code.astro';
import SectionTitle from '../../components/SectionTitle.astro';
import About from '../../components/icons/About.astro';
import AboutMe from '../../components/AboutMe.astro';
import Skills from '../../components/Skills.astro';
---

<Layout title="Valentino Gasipi – Desarrollador Web Full Stack | Vue.js · React · Laravel" description="Desarrollador Web Full Stack especializado en Vue.js, React, Laravel y Firebase. 6 proyectos en producción. Buenos Aires.">
	<main>
		<SectionContainer id="home/">
		<div class="flex flex-row items-center gap-4 mb-4">
			<img src="../yo.jpeg" alt="Valentino Gasipi Falabella" class="rounded-full size-24">

			<a href="https://www.linkedin.com/in/valentino-gasipi-470100252/" target="_blank" rel="noopener">
				<Label>Disponible para trabajar</Label>
			  </a>
		</div>
		<h1 class="text-4xl font-semibold text-gray-800 sm:text-5xl dark:text-white mb-8">
    		Hola, soy Valentino 
  		</h1>
		<h2 class="text-xl md:text-2xl text-wrap"><span class="text-blue-600 dark:text-blue-300">Desarrollador Web Full Stack</span>
		<span class="text-black dark:opacity-80 dark:text-white"> construyendo productos reales con Vue.js, React, Laravel y Firebase.</span> <span class="text-blue-600 dark:text-blue-300 opacity-100">6 proyectos en producción. Buscando mi primer rol a tiempo completo.</span>
		</h2>

		<nav class="flex gap-2 mt-4 flex-wrap justify-center md:justify-start md:gap-6">
				<IntroSocial href="https://www.linkedin.com/in/valentino-gasipi-470100252/">
					<Linkedin class="size-5 md:size-7"/>
					LinkedIn
				</IntroSocial>

				<IntroSocial href="https://github.com/GasipiValentino">
					<Github class="size-5 md:size-7"/>
					GitHub
				</IntroSocial>

				<!-- <IntroSocial href="https://bento.me/valen-gasipi">
					<Bento class="size-5 md:size-7"/>
					Bento
				</IntroSocial> -->

				<IntroSocial href="mailto:valentinogasipi@gmail.com">
					<Mail class="size-5 md:size-7"/>
					valentinogasipi@gmail.com
				</IntroSocial>
		</nav>

	</SectionContainer>

		<SectionContainer id="experience/">
			<SectionTitle>
				<Suitcase class=""/>
				Experiencia Laboral</SectionTitle>
			<Experience/>
		</SectionContainer>

		<SectionContainer id="skills/">
			<SectionTitle>
				<Code class="size-6"/>
				Stack Tecnológico</SectionTitle>
				<Skills/>
		</SectionContainer>

		<SectionContainer id="projects/">
			<SectionTitle>
				<Code class="size-6"/>
				Proyectos</SectionTitle>
				<Projects/>
		</SectionContainer>

		<SectionContainer id="about-me/">
			<SectionTitle>
				<About class="size-6"/>
				Sobre Mi</SectionTitle>
				<AboutMe/>
		</SectionContainer>
	</main>
</Layout>
